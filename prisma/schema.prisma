  warehouseType               String
  address                     String
  googleLocation              String?
  city                        String
  state                       String
  postalCode                  String?
  zone                        String
  contactPerson               String
  contactNumber               String
  totalSpaceSqft              Int[]
  offeredSpaceSqft            String?
  numberOfDocks               String?
  clearHeightFt               String?
  compliances                 String
  otherSpecifications         String?
  ratePerSqft                 String
  availability                String?
  uploadedBy                  String
  isBroker                    String?
  photos                      String?
  createdAt                   DateTime?      @default(now())
  statusUpdatedAt             DateTime?      @updatedAt @map("status_updated_at")
  id                          Int            @id @default(autoincrement())
  visibility                  Boolean?       @default(false)
  media                       Json?
  alt_phone_number            String?
  land_parcel_size            String?
  builtup_area                String?
  owner_warmnth               String?
  distance_from_highway       String?
  is_builder                  Boolean?
  owner_of_multiple_sites     String?
  carpet_area                 String?
  nearest_transport           String?
  fire_exits                  String?
  fire_compliance_cert_type   String?
  negotiated_rent             String?
  washroom_count              String?
  ownerCompanyName            String?
  ownerAltPoc                 String?
  gateSizeFt                  String?
  dockApronLengthFt           String?
  setbackArea                 String?
  ccRoads                     String?
  wallAndSecurityRoom         String?
  plinthHeightFt              String?
  dockDimension               String?
  canopyType                  String?
  dockPlatformType            String?
  otherDockingSpecs           String?
  flooringType                String?
  floorStrengthPerSqm         String?
  ventilationType             String?
  ventilationAirChangesPerDay String?
  insulationPresent           String?
  insulationType              String?
  lightingDetails             String?
  wogVerified                 Boolean?
  centreHeight                String?
  listing_type                String?
  photosWebp                  String?
  handoverDate                DateTime?      @db.Date
  lockInDate                  DateTime?      @db.Date
  status                      String?
  cam                         String?
  chargeableArea              Int?
  warehouseData               WarehouseData?

  @@index([address(ops: raw("gin_trgm_ops"))], map: "idx_warehouse_address_trgm", type: Gin)
  @@index([clearHeightFt], map: "idx_warehouse_clear_height")
  @@index([id, city, state, warehouseType, ratePerSqft, address, zone, contactPerson], map: "idx_warehouse_common_fields")
  @@index([compliances(ops: raw("gin_trgm_ops"))], map: "idx_warehouse_compliances_trgm", type: Gin)
  @@index([ratePerSqft], map: "idx_warehouse_rate")
  @@index([totalSpaceSqft], map: "idx_warehouse_space_gin", type: Gin)
}

model MessageLog {
  id           Int      @id @default(autoincrement())
  receivedAt   DateTime @default(now()) @map("received_at")
  senderNumber String   @map("sender_number")
  messageBody  String   @map("message_body")
  status       String
  errorMessage String?  @map("error_message")
  imageUrl     String?  @map("image_url")
}

model VerifiedNumber {
  id                  Int       @id @default(autoincrement())
  phoneNumber         String    @unique @map("phone_number")
  name                String
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  twenty_user_id      String?   @unique(map: "verified_number_twenty_user_id_key")
  email               String?   @unique(map: "verified_number_email_key")
  empID               String?   @unique(map: "verified_number_empID_key")
  role                String    @default("EMPLOYEE")
  adminAccess         Boolean   @default(false)
  callDashboardAccess Boolean   @default(false)
  dashboardAccess     Boolean   @default(false)
  reviewerAccess      Boolean   @default(false)
  Employee            Employee?
  AgentSession        AgentSession?
  Conversation        Conversation?
  MediaContext        MediaContext?
  Reminder            Reminder[]
  Task                Task[]
}

model Draft {
  senderNumber  String   @id @map("sender_number")
  status        String
  warehouseData Json     @map("warehouse_data")
  imageUrls     String[] @map("image_urls")
  createdAt     DateTime @default(now()) @map("created_at")
}

// Sticky OpenClaw assistant session: once a user sends /bot or /content, their plain
// messages route to that agent until expiresAt (48h, refreshed per message) or they
// send an exit command. Keyed by sender, like Draft.
model AgentSession {
  senderNumber   String         @id @map("sender_number")
  agent          String
  expiresAt      DateTime       @map("expires_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  verifiedNumber VerifiedNumber @relation(fields: [senderNumber], references: [phoneNumber], onDelete: Cascade)

  @@map("agent_session")
}

// Per-user task list / scratchpad — standing to-dos the assistant manages (add / list /
// complete). Distinct from timed Reminders. DB-backed + isolated per sender (FK).
model Task {
  id             Int            @id @default(autoincrement())
  senderNumber   String         @map("sender_number")
  text           String
  done           Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map("created_at")
  doneAt         DateTime?      @map("done_at")
  verifiedNumber VerifiedNumber @relation(fields: [senderNumber], references: [phoneNumber], onDelete: Cascade)

  @@index([senderNumber, done])
  @@map("task")
}

// Scheduled reminders (≤24h). Persisted so they survive bot restarts/redeploys: a
// background poller fires due ones via Twilio and marks them. Keyed by sender (FK).
model Reminder {
  id             Int            @id @default(autoincrement())
  senderNumber   String         @map("sender_number") // recipient (rep)
  fromNumber     String         @map("from_number")   // bot's WhatsApp number to send from
  text           String
  dueAt          DateTime       @map("due_at")
  status         String         @default("pending") // pending | sent | failed | missed
  createdAt      DateTime       @default(now()) @map("created_at")
  verifiedNumber VerifiedNumber @relation(fields: [senderNumber], references: [phoneNumber], onDelete: Cascade)

  @@index([status, dueAt])
  @@map("reminder")
}

// Active media attachment ("pin") per user. Image bytes live in R2 (r2Url); PDF/doc text
// is kept inline. Re-attached to the user's agent turns until expiresAt (sliding). DB-backed
// so it survives bot restarts and supports long pin windows without holding bytes in RAM.
model MediaContext {
  senderNumber   String         @id @map("sender_number")
  kind           String // image | pdf | doc
  r2Url          String?        @map("r2_url") // images: bytes in R2
  mime           String?
  text           String? // pdf/doc: extracted text
  truncated      Boolean        @default(false)
  expiresAt      DateTime       @map("expires_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  verifiedNumber VerifiedNumber @relation(fields: [senderNumber], references: [phoneNumber], onDelete: Cascade)

  @@map("media_context")
}

// Bot-owned conversation history per user. The bot sends these turns to OpenClaw on
// each call so memory is deterministic (survives gateway/bot restarts) and isolated
// (keyed by sender — never shared across users). Capped to the most recent turns.
model Conversation {
  senderNumber   String         @id @map("sender_number")
  turns          Json // [{ role: "user"|"assistant", content: "..." }], most-recent-last
  updatedAt      DateTime       @updatedAt @map("updated_at")
  verifiedNumber VerifiedNumber @relation(fields: [senderNumber], references: [phoneNumber], onDelete: Cascade)

  @@map("conversation")
}

model WarehouseData {
  id                  Int                    @id @default(autoincrement())
  latitude            Float?
  longitude           Float?
  embedding           Unsupported("vector")?
  warehouseId         Int                    @unique
  fireNocAvailable    Boolean?
  fireSafetyMeasures  String?
  landType            String?
  approachRoadWidth   String?
  dimensions          String?
  parkingDockingSpace String?
  pollutionZone       String?
  powerKva            String?
  vaastuCompliance    String?
  warehouse           Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
}

model Enquiry {
  id           Int       @id @default(autoincrement())
  name         String
  phone_number String
  email        String?
  source       String
  createdat    DateTime? @default(now()) @db.Timestamptz(6)
}

model customer_request {
  id                      BigInt    @id @default(autoincrement())
  full_name               String
